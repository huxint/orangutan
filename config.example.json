{
  "agent": {
    "profile": "anthropic-main",
    "model": "claude-sonnet-4-20250514",
    "workspace": "~/workspace"
  },
  "permissions": {
    "default_mode": "default_mode",
    "allow": ["read", "task(list)"],
    "deny": ["shell(rm:*)"],
    "ask": ["edit", "write", "shell"]
  },
  "session": {
    "auto_save": true
  },
  "memory": {
    "mirror_enabled": false,
    "mirror_file": ".orangutan/memory/MEMORY.md",
    "journal_dir": ".orangutan/memory/journal"
  },
  "security": {
    "allow": [
      "cli:*",
      "qqbot:primary:*",
      "qqbot:coder-bot:*",
      "qqbot:research-bot:*"
    ],
    "deny": []
  },
  "profiles": {
    "anthropic-main": {
      "base_url": "https://api.anthropic.com",
      "api_key": "${ANTHROPIC_API_KEY}",
      "headers": {
        "anthropic-version": "2023-06-01"
      },
      "models": {
        "claude-sonnet-4-20250514": {
          "provider": "anthropic",
          "protocol": "messages",
          "thinking": "medium",
          "context_window": 200000
        }
      }
    }
  },
  "agents": {
    "default": {
      "leader_mode": true,
      "max_concurrent_agents": 4
    },
    "coder": {
      "permissions": {
        "default_mode": "default_mode",
        "allow": ["read", "edit"],
        "deny": ["shell(git push *)"],
        "ask": ["shell"]
      }
    },
    "research": {
      "thinking_budget": 2048
    }
  },
  "qq_bots": [
    {
      "name": "primary",
      "app_id": "${QQ_APP_ID_PRIMARY}",
      "client_secret": "${QQ_CLIENT_SECRET_PRIMARY}",
      "agent": "default"
    },
    {
      "name": "coder-bot",
      "app_id": "${QQ_APP_ID_CODER}",
      "client_secret": "${QQ_CLIENT_SECRET_CODER}",
      "agent": "coder"
    },
    {
      "name": "research-bot",
      "app_id": "${QQ_APP_ID_RESEARCH}",
      "client_secret": "${QQ_CLIENT_SECRET_RESEARCH}",
      "agent": "research"
    }
  ]
}
