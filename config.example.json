{
  "session": {
    "auto_save": true
  },
  "permissions": {
    "sandbox_mode": "isolated",
    "shell_approval_policy": "ask",
    "denied_shell_commands": [
      "rm -rf /",
      "shutdown",
      "reboot"
    ]
  },
  "memory": {
    "mirror_enabled": false,
    "mirror_file": "MEMORY.md",
    "journal_dir": "memory"
  },
  "security": {
    "allow": [
      "cli:*",
      "qqbot:primary:*",
      "qqbot:coder-bot:*",
      "qqbot:research-bot:*"
    ],
    "deny": []
  },
  "profiles": {
    "anthropic-main": {
      "base_url": "https://api.anthropic.com",
      "api_key": "${ANTHROPIC_API_KEY}",
      "headers": {
        "anthropic-version": "2023-06-01"
      },
      "models": {
        "claude-sonnet-4-20250514": {
          "endpoint_style": "anthropic-messages",
          "thinking": "medium",
          "context_window": 200000
        }
      }
    }
  },
  "agents": {
    "default": {
      "profile": "anthropic-main",
      "model": "claude-sonnet-4-20250514",
      "workspace": "~/.orangutan/workspace/default",
      "system_prompt": "You are the default general assistant.",
      "subagents": [
        "coder",
        "research"
      ]
    },
    "coder": {
      "profile": "anthropic-main",
      "model": "claude-sonnet-4-20250514",
      "workspace": "~/.orangutan/workspace/coder",
      "system_prompt": "You focus on code changes, debugging, and implementation details.",
      "subagents": [
        "research"
      ],
      "permissions": {
        "sandbox_mode": "isolated",
        "shell_approval_policy": "ask",
        "denied_shell_commands": [
          "git push",
          "rm -rf /"
        ]
      }
    },
    "research": {
      "profile": "anthropic-main",
      "model": "claude-sonnet-4-20250514",
      "workspace": "~/.orangutan/workspace/research",
      "system_prompt": "You focus on analysis, investigation, and planning.",
      "subagents": []
    }
  },
  "qq_bots": [
    {
      "name": "primary",
      "app_id": "QQ_APP_ID_PRIMARY",
      "client_secret": "QQ_CLIENT_SECRET_PRIMARY",
      "agent": "default"
    },
    {
      "name": "coder-bot",
      "app_id": "QQ_APP_ID_CODER",
      "client_secret": "QQ_CLIENT_SECRET_CODER",
      "agent": "coder"
    },
    {
      "name": "research-bot",
      "app_id": "QQ_APP_ID_RESEARCH",
      "client_secret": "QQ_CLIENT_SECRET_RESEARCH",
      "agent": "research"
    }
  ]
}
