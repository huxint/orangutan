{
  "session": {
    "auto_save": true
  },
  "permissions": {
    "default_mode": "default_mode",
    "allow": ["file_read", "glob", "grep"],
    "deny": [],
    "ask": ["shell"]
  },
  "memory": {
    "mirror_enabled": false,
    "mirror_file": ".orangutan/memory/MEMORY.md",
    "journal_dir": ".orangutan/memory/journal"
  },
  "security": {
    "allow": [
      "cli:*",
      "qqbot:primary:*",
      "qqbot:coder-bot:*",
      "qqbot:research-bot:*"
    ],
    "deny": []
  },
  "profiles": {
    "anthropic-main": {
      "base_url": "https://api.anthropic.com",
      "api_key": "${ANTHROPIC_API_KEY}",
      "headers": {
        "anthropic-version": "2023-06-01"
      },
      "models": {
        "claude-sonnet-4-20250514": {
          "endpoint_style": "anthropic-messages",
          "thinking": "medium",
          "context_window": 200000
        }
      }
    }
  },
  "agents": {
    "default": {
      "profile": "anthropic-main",
      "model": "claude-sonnet-4-20250514",
      "workspace": "~/workspace",
      "system_prompt": "You are the default general assistant.",
      "coordinator_mode": true,
      "team_agents": [
        "coder",
        "research"
      ],
      "max_concurrent_agents": 4
    },
    "coder": {
      "profile": "anthropic-main",
      "model": "claude-sonnet-4-20250514",
      "workspace": "~/workspace",
      "system_prompt": "You focus on code changes, debugging, and implementation details.",
      "team_agents": [
        "research"
      ],
      "permissions": {
        "default_mode": "default_mode",
        "allow": [],
        "deny": [],
        "ask": ["shell"]
      }
    },
    "research": {
      "profile": "anthropic-main",
      "model": "claude-sonnet-4-20250514",
      "workspace": "~/workspace",
      "system_prompt": "You focus on analysis, investigation, and planning.",
      "team_agents": []
    }
  },
  "qq_bots": [
    {
      "name": "primary",
      "app_id": "QQ_APP_ID_PRIMARY",
      "client_secret": "QQ_CLIENT_SECRET_PRIMARY",
      "agent": "default"
    },
    {
      "name": "coder-bot",
      "app_id": "QQ_APP_ID_CODER",
      "client_secret": "QQ_CLIENT_SECRET_CODER",
      "agent": "coder"
    },
    {
      "name": "research-bot",
      "app_id": "QQ_APP_ID_RESEARCH",
      "client_secret": "QQ_CLIENT_SECRET_RESEARCH",
      "agent": "research"
    }
  ]
}
